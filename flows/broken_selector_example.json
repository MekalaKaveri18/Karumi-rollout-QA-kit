{
  "name": "Northwind CRM \u2014 broken selector demo (for testing failure handling)",
  "base_url": "http://127.0.0.1:5050",
  "steps": [
    { "action": "navigate", "path": "/login", "description": "Open login page" },
    { "action": "dismiss_if_present", "selector": "#cookie-accept", "wait_ms": 1500, "description": "Dismiss cookie banner if shown" },
    { "action": "fill", "selector": "#username", "value": "demo_fde", "description": "Enter username" },
    { "action": "fill", "selector": "#password", "value": "demo123", "description": "Enter password" },
    { "action": "click", "selector": "#login-submit", "description": "Submit login" },
    { "action": "wait_for", "selector": ".stat-grid", "description": "Wait for dashboard to load" },
    { "action": "click", "selector": "#nav-contacts", "description": "Navigate to Contacts (skips dismissing the 'what's new' modal on purpose)" },
    { "action": "wait_for", "selector": "#contacts-table-typo", "timeout_ms": 2500, "retries": 1, "retry_delay_ms": 500, "description": "Wait for a selector that doesn't exist" }
  ]
}
